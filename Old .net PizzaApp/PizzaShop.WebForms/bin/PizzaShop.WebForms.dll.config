<?xml version="1.0" encoding="utf-8"?>
<!--
  LEGACY PATTERN: Web.config XML-based configuration
  MODERNIZATION PATH: appsettings.json with strongly-typed configuration
-->
<configuration>
  <appSettings>
    <!-- Application settings -->
    <add key="PizzaShopName" value="Artisan Pizza Shop" />
    <add key="EnableCustomPizzas" value="true" />
    
    <!-- LEGACY PATTERN: AppSettings for configuration -->
    <!-- MODERNIZATION NOTE: Replace with IConfiguration and strongly-typed options -->
  </appSettings>
  
  <connectionStrings>
    <!-- 
      LEGACY PATTERN: In-memory data simulation, no real database
      MODERNIZATION PATH: Add real connection string for Azure SQL or Cosmos DB
    -->
    <add name="PizzaShopDB" 
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=PizzaShop;Integrated Security=True" 
         providerName="System.Data.SqlClient"/>
  </connectionStrings>
  
  <system.web>
    <!-- Compilation settings for .NET Framework 4.7.2 -->
    <compilation debug="true" targetFramework="4.7.2"/>
    
    <!-- 
      LEGACY PATTERN: Session state in-process (InProc mode)
      MODERNIZATION NOTE: Session stored in server memory, not scalable
      MODERNIZATION PATH: Distributed cache (Redis) or stateless design
    -->
    <sessionState mode="InProc" timeout="30"/>
    
    <!-- HTTP Runtime settings -->
    <httpRuntime targetFramework="4.7.2" maxRequestLength="10240" executionTimeout="90"/>
    
    <!-- Pages configuration -->
    <pages controlRenderingCompatibilityVersion="4.0" 
           clientIDMode="AutoID"
           enableViewState="true"
           validateRequest="true">
      <!-- 
        LEGACY PATTERN: ViewState enabled globally
        MODERNIZATION NOTE: ViewState increases page size significantly
        MODERNIZATION PATH: Client-side state management or server component state
      -->
      <namespaces>
        <add namespace="System.Web.UI"/>
        <add namespace="System.Web.UI.WebControls"/>
      </namespaces>
    </pages>
    
    <!-- Custom errors configuration -->
    <customErrors mode="Off"/>
    
    <!-- Authentication -->
    <authentication mode="None">
      <!-- 
        LEGACY PATTERN: Forms authentication commonly used
        MODERNIZATION PATH: Azure AD B2C or ASP.NET Core Identity
      -->
    </authentication>
    
    <!-- Globalization -->
    <globalization culture="en-US" uiCulture="en-US"/>
  </system.web>
  
  <system.webServer>
    <!-- IIS configuration -->
    <modules runAllManagedModulesForAllRequests="true"/>
    
    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear/>
        <add value="Default.aspx"/>
      </files>
    </defaultDocument>
    
    <!-- Static content handling -->
    <staticContent>
      <remove fileExtension=".woff"/>
      <mimeMap fileExtension=".woff" mimeType="application/font-woff"/>
      <remove fileExtension=".woff2"/>
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2"/>
    </staticContent>
    
    <!-- 
      LEGACY PATTERN: IIS-specific configuration in Web.config
      MODERNIZATION PATH: Kestrel web server with minimal configuration
    -->
  </system.webServer>
  
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Assembly redirects if needed -->
    </assemblyBinding>
  </runtime>
</configuration>
